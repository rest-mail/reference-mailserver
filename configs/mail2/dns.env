# DNS facts for the mail2 instance.
# Mounted into the reference-dnsmasq image's `render-fragment` subcommand
# at `task up CONFIG=mail2` to register this instance with the testbed.

MAIL_NAME=mail2
MAIL_HOSTNAME=mail2.test
MAIL_IP=10.99.0.12
POSTGRES_IP=10.99.0.42
MAIL_PTR=12.0.99.10.in-addr.arpa
MTA_STS_ID=20260218

# Testbed contract: API lives at this IP across the testbed network.
API_IP=10.99.0.20
