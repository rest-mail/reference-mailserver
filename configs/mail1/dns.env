# DNS facts for the mail1 instance.
# Mounted into the reference-dnsmasq image's `render-fragment` subcommand
# at `task up CONFIG=mail1` to register this instance with the testbed.

MAIL_NAME=mail1
MAIL_HOSTNAME=mail1.test
MAIL_IP=10.99.0.11
POSTGRES_IP=10.99.0.41
MAIL_PTR=11.0.99.10.in-addr.arpa
MTA_STS_ID=20260218

# Testbed contract: API lives at this IP across the testbed network.
API_IP=10.99.0.20
